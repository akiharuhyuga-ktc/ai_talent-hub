{
  "name": "ktc-talent-hub",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "setup": "bash scripts/setup.sh",
    "dev": "bash scripts/setup.sh && docker compose up",
    "dev:build": "bash scripts/setup.sh && docker compose up --build",
    "dev:frontend": "cd frontend && pnpm dev",
    "dev:backend": "cd backend && go run .",
    "lint": "cd frontend && pnpm lint",
    "format": "cd frontend && pnpm format",
    "typecheck": "cd frontend && pnpm typecheck",
    "test": "cd frontend && pnpm test:run"
  }
}
